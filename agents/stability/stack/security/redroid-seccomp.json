    {
      "_group": "magisk-mount-bind (CAP_SYS_ADMIN-gated; required for /proc/cpuinfo overlay in service.sh)",
      "names": [
        "mount", "umount", "umount2", "pivot_root", "swapon", "swapoff",
        "open_tree", "move_mount", "fsopen", "fsconfig", "fsmount",
        "fspick", "mount_setattr"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_group": "namespace-create (Android zygote + Magisk magiskhide need clone+unshare; setns blocked)",
      "names": ["clone", "clone3", "unshare"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_group": "binder-keyring (Android keystore + Magisk policy load)",
      "names": ["add_key", "keyctl", "request_key"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_group": "ptrace (debuggable for Magisk + tracer-pid management; blocked outside container by no-new-privileges)",
      "names": ["ptrace", "process_vm_readv", "process_vm_writev"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_group": "perf-and-bpf (Android Profiler + RenderScript dispatch). bpf is allowed but kernel BPF JIT must be off on host.",
      "names": ["perf_event_open", "bpf"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_group": "explicit-deny (kernel-state-mutating syscalls Android does NOT need at runtime; absence here means defaultAction (ERRNO 1) applies. Listed here for documentation only — they are NOT in any allow group above.) init_module finit_module delete_module create_module query_module kexec_load kexec_file_load reboot iopl ioperm acct quotactl lookup_dcookie nfsservctl personality vhangup pivot_root_too uselib ustat sysfs setdomainname sethostname",
